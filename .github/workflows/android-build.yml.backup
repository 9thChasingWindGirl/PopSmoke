name: PopSmoke Android平台 构建

on:
  push:
    branches:
      - main
  pull_request:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: 设置 Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '22'
      - name: 安装 pnpm
        uses: pnpm/action-setup@v3
        with:
          version: latest
      - name: 安装依赖
        run: pnpm install
      - name: 构建 Web 应用
        run: pnpm build
      - name: 同步 Capacitor 配置
        run: pnpm exec capacitor sync android
      - name: 设置 JDK
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'
      - name: 安装 Android 命令行工具
        run: |
          wget https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip
          unzip commandlinetools-linux-11076708_latest.zip -d android-sdk-tmp
          mkdir -p android-sdk/cmdline-tools
          mv android-sdk-tmp/cmdline-tools android-sdk/cmdline-tools/latest
          rm -rf android-sdk-tmp
          rm commandlinetools-linux-11076708_latest.zip
      - name: 安装 SDK 依赖
        run: |
          export ANDROID_HOME=$PWD/android-sdk
          export PATH=$PATH:$ANDROID_HOME/cmdline-tools/latest/bin
          yes | sdkmanager --licenses
          sdkmanager "platform-tools" "platforms;android-34" "build-tools;34.0.0"
      - name: 同步 Gradle
        run: |
          cd android
          chmod +x gradlew
          export JAVA_HOME=/opt/hostedtoolcache/Java_Temurin-Hotspot_jdk/17.0.18-8/x64
          export PATH=$JAVA_HOME/bin:$PATH
          # 修改 capacitor.build.gradle 文件，将 Java 版本从 21 改为 17
          sed -i 's/JavaVersion.VERSION_21/JavaVersion.VERSION_17/g' app/capacitor.build.gradle
          # 修改 capacitor-android 模块的 build.gradle 文件，将 Java 版本从 21 改为 17
          sed -i 's/JavaVersion.VERSION_21/JavaVersion.VERSION_17/g' ../node_modules/.pnpm/@capacitor+android@8.2.0_@capacitor+core@8.2.0/node_modules/@capacitor/android/capacitor/build.gradle
          # 修改 capacitor-community-sqlite 模块的 build.gradle 文件，将 Java 版本从 21 改为 17
          sed -i 's/JavaVersion.VERSION_21/JavaVersion.VERSION_17/g' ../node_modules/.pnpm/@capacitor-community+sqlite@8.0.1_@capacitor+core@8.2.0/node_modules/@capacitor-community/sqlite/android/build.gradle
          # 修改 capacitor-preferences 模块的 build.gradle 文件，将 Java 版本从 21 改为 17
          find ../node_modules -path "*@capacitor/preferences*" -name "build.gradle" -exec sed -i 's/JavaVersion.VERSION_21/JavaVersion.VERSION_17/g' {} \;
          ./gradlew --version
      - name: 构建 APK
        run: |
          cd android
          chmod +x gradlew
          export JAVA_HOME=/opt/hostedtoolcache/Java_Temurin-Hotspot_jdk/17.0.18-8/x64
          export PATH=$JAVA_HOME/bin:$PATH
          # 再次修改 capacitor.build.gradle 文件，确保 Java 版本为 17
          sed -i 's/JavaVersion.VERSION_21/JavaVersion.VERSION_17/g' app/capacitor.build.gradle
          # 再次修改 capacitor-android 模块的 build.gradle 文件，确保 Java 版本为 17
          sed -i 's/JavaVersion.VERSION_21/JavaVersion.VERSION_17/g' ../node_modules/.pnpm/@capacitor+android@8.2.0_@capacitor+core@8.2.0/node_modules/@capacitor/android/capacitor/build.gradle
          # 再次修改 capacitor-community-sqlite 模块的 build.gradle 文件，确保 Java 版本为 17
          sed -i 's/JavaVersion.VERSION_21/JavaVersion.VERSION_17/g' ../node_modules/.pnpm/@capacitor-community+sqlite@8.0.1_@capacitor+core@8.2.0/node_modules/@capacitor-community/sqlite/android/build.gradle
          # 再次修改 capacitor-preferences 模块的 build.gradle 文件，确保 Java 版本为 17
          find ../node_modules -path "*@capacitor/preferences*" -name "build.gradle" -exec sed -i 's/JavaVersion.VERSION_21/JavaVersion.VERSION_17/g' {} \;
          ./gradlew assembleDebug
      - name: 查看构建输出目录结构
        run: |
          ls -la android/app/build/outputs/
          find android/app/build -name "*.apk"
      - name: 上传构建产物
        uses: actions/upload-artifact@v4
        with:
          name: android-apk
          path: android/app/build/outputs/**/*.apk
